<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:left="0dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A1A2E" />
        </shape>
    </item>

    <item
        android:bottom="4dp"
        android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#2A2A3E" />
            <stroke
                android:width="2dp"
                android:color="#4A4A6E" />
        </shape>
    </item>

</layer-list>