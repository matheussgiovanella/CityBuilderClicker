<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:left="0dp"
        android:top="4dp">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="#1A6B1A" />
            </shape>
        </clip>
    </item>

    <item
        android:bottom="4dp"
        android:right="4dp">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="#4CAF50" />
            </shape>
        </clip>
    </item>

    <item
        android:bottom="4dp"
        android:right="4dp"
        android:top="2dp"
        android:left="2dp"
        android:height="3dp"
        android:gravity="top">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="#80FFFFFF" />
            </shape>
        </clip>
    </item>

</layer-list>